{
  "name": "hief",
  "version": "0.1.0",
  "description": "Hybrid Intent Execution Framework - AI DeFi Intent Infrastructure",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/solver-adapters/*"
  ],
  "scripts": {
    "build": "pnpm -r --filter \"!@hief/nft-sync\" --filter \"!@hief/solver-network\" build || true",
    "test": "pnpm -r test",
    "dev": "pnpm --filter @hief/bus dev",
    "lint": "pnpm -r lint",
    "start": "node gateway.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "http-proxy": "^1.18.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "gateway.js"
}
