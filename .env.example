# ─────────────────────────────────────────────────────────────────────────────
# HIEF — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Network ───────────────────────────────────────────────────────────────────
# Base Sepolia (testnet) = 84532
# Base Mainnet           = 8453
CHAIN_ID=84532

# RPC endpoint for Base Sepolia
# Get a free key at: https://www.alchemy.com or https://infura.io
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# OpenAI API key for the Agent service
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── Smart Contracts ───────────────────────────────────────────────────────────
# Deployed ReputationNFT contract address (fill after running deploy script)
REPUTATION_NFT_ADDRESS=0x0000000000000000000000000000000000000000

# ── Wallets / Keys ────────────────────────────────────────────────────────────
# WARNING: Use dedicated hot wallets for testnet only. Never use mainnet keys here.

# Deployer wallet — used to deploy contracts (needs testnet ETH)
DEPLOYER_PRIVATE_KEY=0x...

# Updater wallet — holds UPDATER_ROLE, used by reputation service to write scores on-chain
UPDATER_PRIVATE_KEY=0x...
UPDATER_ADDRESS=0x...

# Guardian wallet — holds GUARDIAN_ROLE, can pause the contract (use a Safe multisig on mainnet)
GUARDIAN_ADDRESS=0x...

# Safe signer — used by solver to sign Safe transactions
SAFE_SIGNER_PRIVATE_KEY=0x...

# ── Solver ────────────────────────────────────────────────────────────────────
# CoW Protocol API endpoint
# Sepolia: https://api.cow.fi/sepolia
# Mainnet: https://api.cow.fi/mainnet
COW_API_URL=https://api.cow.fi/sepolia

# ── Policy Engine ─────────────────────────────────────────────────────────────
# Tenderly credentials for Fork simulation (optional in MVP, required for L4 validation)
# Get at: https://dashboard.tenderly.co
TENDERLY_API_KEY=
TENDERLY_ACCOUNT=
TENDERLY_PROJECT=

# ── Basescan (contract verification) ─────────────────────────────────────────
BASESCAN_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
