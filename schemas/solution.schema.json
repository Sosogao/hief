{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://hief.dev/schemas/solution.schema.json",
    "title": "HIEF Solution (HIEF-SOL-01 v0.1)",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "solutionVersion",
        "solutionId",
        "intentId",
        "intentHash",
        "solverId",
        "executionPlan",
        "quote",
        "stakeSnapshot",
        "signature"
    ],
    "properties": {
        "solutionVersion": { "type": "string", "const": "0.1" },
        "solutionId": { "$ref": "#/$defs/bytes32" },
        "intentId": { "$ref": "#/$defs/bytes32" },
        "intentHash": { "$ref": "#/$defs/bytes32" },
        "solverId": { "$ref": "#/$defs/address" },
        "executionPlan": { "$ref": "#/$defs/executionPlan" },
        "quote": { "$ref": "#/$defs/quote" },
        "stakeSnapshot": { "$ref": "#/$defs/stakeSnapshot" },
        "simulationRef": { "$ref": "#/$defs/simulationRef" },
        "meta": { "type": "object", "additionalProperties": true },
        "extensions": { "type": "object", "additionalProperties": true },
        "signature": { "$ref": "#/$defs/signature" }
    },
    "$defs": {
        "hex": {
            "type": "string",
            "pattern": "^0x[0-9a-fA-F]*$"
        },
        "bytes32": {
            "type": "string",
            "pattern": "^0x[0-9a-fA-F]{64}$"
        },
        "address": {
            "type": "string",
            "pattern": "^0x[0-9a-fA-F]{40}$"
        },
        "uintString": {
            "type": "string",
            "pattern": "^(0|[1-9][0-9]*)$"
        },
        "call": {
            "type": "object",
            "additionalProperties": false,
            "required": ["to", "value", "data", "operation"],
            "properties": {
                "to": { "$ref": "#/$defs/address" },
                "value": { "$ref": "#/$defs/uintString" },
                "data": { "$ref": "#/$defs/hex" },
                "operation": { "type": "string", "const": "CALL" }
            }
        },
        "executionPlan": {
            "type": "object",
            "additionalProperties": false,
            "required": ["calls"],
            "properties": {
                "calls": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "$ref": "#/$defs/call" }
                }
            }
        },
        "quote": {
            "type": "object",
            "additionalProperties": false,
            "required": ["expectedOut", "fee", "validUntil"],
            "properties": {
                "expectedOut": { "$ref": "#/$defs/uintString" },
                "fee": { "$ref": "#/$defs/uintString" },
                "validUntil": { "type": "integer", "minimum": 0 }
            }
        },
        "stakeSnapshot": {
            "type": "object",
            "additionalProperties": false,
            "required": ["amount"],
            "properties": {
                "amount": { "$ref": "#/$defs/uintString" },
                "blockNumber": { "type": "integer", "minimum": 0 }
            }
        },
        "simulationRef": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "value"],
            "properties": {
                "type": { "type": "string" },
                "value": { "type": "string" }
            }
        },
        "signature": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "signer", "sig"],
            "properties": {
                "type": { "type": "string", "enum": ["EIP712_EOA"] },
                "signer": { "$ref": "#/$defs/address" },
                "sig": { "$ref": "#/$defs/hex" }
            }
        }
    }
}
