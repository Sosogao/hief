{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://hief.dev/schemas/intent.schema.json",
    "title": "HIEF Intent (HIEF-INT-01 v0.1)",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "intentVersion",
        "intentId",
        "smartAccount",
        "chainId",
        "deadline",
        "input",
        "outputs",
        "constraints",
        "priorityFee",
        "policyRef",
        "signature"
    ],
    "properties": {
        "intentVersion": { "type": "string", "const": "0.1" },
        "intentId": { "$ref": "#/$defs/bytes32" },
        "smartAccount": { "$ref": "#/$defs/address" },
        "chainId": { "type": "integer", "minimum": 1 },
        "deadline": { "type": "integer", "minimum": 0 },
        "input": { "$ref": "#/$defs/inputAsset" },
        "outputs": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/outputConstraint" }
        },
        "constraints": { "$ref": "#/$defs/constraints" },
        "priorityFee": { "$ref": "#/$defs/priorityFee" },
        "policyRef": { "$ref": "#/$defs/policyRef" },
        "reputationSnapshotRef": { "$ref": "#/$defs/reputationSnapshotRef" },
        "meta": { "type": "object", "additionalProperties": true },
        "extensions": { "type": "object", "additionalProperties": true },
        "signature": { "$ref": "#/$defs/signature" }
    },
    "$defs": {
        "hex": {
            "type": "string",
            "pattern": "^0x[0-9a-fA-F]*$"
        },
        "bytes32": {
            "type": "string",
            "pattern": "^0x[0-9a-fA-F]{64}$"
        },
        "address": {
            "type": "string",
            "pattern": "^0x[0-9a-fA-F]{40}$"
        },
        "uintString": {
            "type": "string",
            "pattern": "^(0|[1-9][0-9]*)$"
        },
        "inputAsset": {
            "type": "object",
            "additionalProperties": false,
            "required": ["token", "amount"],
            "properties": {
                "token": { "$ref": "#/$defs/address" },
                "amount": { "$ref": "#/$defs/uintString" }
            }
        },
        "outputConstraint": {
            "type": "object",
            "additionalProperties": false,
            "required": ["token", "minAmount"],
            "properties": {
                "token": { "$ref": "#/$defs/address" },
                "minAmount": { "$ref": "#/$defs/uintString" },
                "recipient": { "$ref": "#/$defs/address" }
            }
        },
        "constraints": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "slippageBps": { "type": "integer", "minimum": 0, "maximum": 10000 },
                "maxSpend": { "$ref": "#/$defs/uintString" },
                "nonceSalt": { "$ref": "#/$defs/bytes32" }
            }
        },
        "priorityFee": {
            "type": "object",
            "additionalProperties": false,
            "required": ["token", "amount"],
            "properties": {
                "token": { "type": "string", "const": "HIEF" },
                "amount": { "$ref": "#/$defs/uintString" }
            }
        },
        "policyRef": {
            "type": "object",
            "additionalProperties": false,
            "required": ["policyVersion"],
            "properties": {
                "policyVersion": { "type": "string" },
                "policyHash": { "$ref": "#/$defs/bytes32" }
            }
        },
        "reputationSnapshotRef": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "value"],
            "properties": {
                "type": { "type": "string", "enum": ["block", "hash", "timestamp"] },
                "value": { "type": "string" }
            }
        },
        "signature": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "signer", "sig"],
            "properties": {
                "type": { "type": "string", "enum": ["EIP712_EOA", "SAFE", "ERC1271"] },
                "signer": { "$ref": "#/$defs/address" },
                "sig": { "$ref": "#/$defs/hex" }
            }
        }
    }
}
